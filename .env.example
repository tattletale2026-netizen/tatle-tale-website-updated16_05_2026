# Tatle Tale production environment variables
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=replace-with-a-long-random-secret

# Booking limit
MAX_BOOKINGS=10

# Email recipient
MAIL_TO=tattletale2026@gmail.com

# Resend email settings
RESEND_API_KEY=replace-with-your-resend-api-key
RESEND_FROM=Tatle Tale <onboarding@resend.dev>

# Optional SMTP fallback values
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
